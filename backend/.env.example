# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCOUNT_ID=your-account-id

# AWS Resources (from CloudFormation outputs)
BUCKET_NAME=tcg-marketplace-dev-storage-your-account-id
TABLE_NAME=tcg-marketplace-dev-data

# Cognito Configuration (when auth is deployed)
USER_POOL_ID=your-user-pool-id
USER_POOL_CLIENT_ID=your-user-pool-client-id
USER_POOL_GROUPS=Sellers,Viewers,Admins

# Security
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Optional (Phase 2)
JWT_SECRET=your-jwt-secret

# NOTE: For local development, copy this file to .env.local
# The application loads .env.local first, then falls back to .env
# This allows you to keep local overrides without committing them to git
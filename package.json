{
  "name": "tcg-marketplace",
  "version": "1.0.0",
  "description": "A full-stack web application designed for the trading card game market. This project serves as a technical implementation of a React-based frontend and a Next.js backend, integrated with AWS cloud services for data and asset management.",
  "homepage": "https://github.com/nus-iss-team1/tcg-marketplace#readme",
  "bugs": {
    "url": "https://github.com/nus-iss-team1/tcg-marketplace/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nus-iss-team1/tcg-marketplace.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "web-build": " docker build -f frontend/Dockerfile -t ghcr.io/nus-iss-team1/tcg-marketplace:latest .",
    "web-run": "docker run -d -p 3000:3000 ghcr.io/nus-iss-team1/tcg-marketplace:latest    ",
    "listing-build": " docker build -f backend/listing-service/Dockerfile -t ghcr.io/nus-iss-team1/tcg-marketplace:latest .",
    "listing-run": "docker run -d -p 3001:3001 ghcr.io/nus-iss-team1/tcg-marketplace:latest    ",
    "messaging-build": " docker build -f backend/messaging-service/Dockerfile -t ghcr.io/nus-iss-team1/tcg-marketplace:latest .",
    "messaging-run": "docker run -d -p 3002:3002 ghcr.io/nus-iss-team1/tcg-marketplace:latest    ",
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/listing-service/src/**/*.ts": "cd backend/listing-service && npx eslint",
    "backend/messaging-service/src/**/*.ts": "cd backend/messaging-service && npx eslint",
    "frontend/src/**/*.{ts,tsx}": "cd frontend && npx eslint"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}

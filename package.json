{
  "name": "tcg-marketplace",
  "version": "1.0.0",
  "description": "TCG Marketplace - Trading Card Game marketplace platform",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install": "npm install --workspaces",
    "build": "npm run build --workspaces",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run start:dev --workspace=backend\"",
    "web-build": "docker build -t tcg-marketplace-frontend ./frontend",
    "web-run": "docker run -p 3000:3000 tcg-marketplace-frontend",
    "backend-build": "docker build -t tcg-marketplace-backend ./backend",
    "backend-run": "docker run -p 3001:3000 tcg-marketplace-backend",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "npm run format --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "TCG Marketplace Team",
  "license": "UNLICENSED"
}